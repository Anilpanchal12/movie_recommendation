<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Categories</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        /* Specific overrides for category cards to make them look distinct */
        .genre-container {
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 30px;
        }
        .genre-card {
            aspect-ratio: 16 / 9;
            background: #111;
            border: 1px solid var(--glass-border);
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            border-radius: var(--radius-md);
            transform-style: preserve-3d;
            transition: transform var(--transition-cinematic), box-shadow var(--transition-cinematic);
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            text-decoration: none;
            overflow: hidden;
            position: relative;
        }
        .genre-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 50% 50%, rgba(255, 150, 150, 0.2), transparent 70%);
            opacity: 0;
            transition: opacity var(--transition-fast);
        }
        .genre-card:hover {
            transform: translateY(-10px) translateZ(20px) rotateX(5deg);
            box-shadow: 0 20px 40px rgba(255, 0, 51, 0.3);
            border-color: var(--primary);
        }
        .genre-card:hover::before {
            opacity: 1;
        }
        .genre-card h3 {
            font-size: 1.5rem;
            color: #fff;
            text-shadow: 0 4px 15px rgba(255,0,51,0.8);
            transform: translateZ(30px);
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
    </style>
</head>
<body>

<div class="bg-mesh"></div>

<div id="sidebar-overlay"></div>

<header>
    <div class="brand-container">
        <button id="menuBtn" class="menu-btn" aria-label="Open Menu">☰</button>
        <h1>🎬 <span>Cinematic</span></h1>
    </div>
    <form action="/search" method="GET" class="search-form">
        <input type="text" name="query" placeholder="Search Movies..." required>
        <button type="submit">Search</button>
    </form>
</header>

<nav>
    <a href="/">🏠 Home</a>
    <a href="/popular">Popular</a>
    <a href="/top-rated">Top Rated</a>
    <a href="/upcoming">Upcoming</a>
    <a href="/categories">Categories</a>
</nav>

<main>
    <h2>🍿 Browse by Category</h2>
    
    <% if(genres.length === 0){ %>
        <div class="no-movies">
            <h3>No Categories Available</h3>
        </div>
    <% } else { %>
        <div class="movie-container genre-container">
            <% genres.forEach(genre => { %>
                <a href="/genre/<%= genre.id %>" class="genre-card">
                    <h3><%= genre.name %></h3>
                </a>
            <% }) %>
        </div>
    <% } %>
</main>

<footer>
    <p>This product uses the TMDB API but is not endorsed or certified by TMDB.</p>
</footer>

<script src="/script.js"></script>
</body>
</html>
